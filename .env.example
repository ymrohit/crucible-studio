# Copy to `.env` and fill in real values. Do not commit `.env`.

# Required: powers the Crucible agent loop on Gemma 4 31B.
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Optional: enables the Google AI Studio/Gemma baseline in the left pane.
# Aliases also accepted by the code: aistudio_gemma4_key, GOOGLE_API_KEY, GEMINI_API_KEY.
AISTUDIO_GEMMA4_KEY=your_google_ai_studio_key_here

# Optional overrides.
CRUCIBLE_MODEL=gemma-4-31b
CRUCIBLE_SANDBOX=local
